-        dma_channel_set_irq0_enabled(dma_channel, true);
-        irq_set_exclusive_handler(DMA_IRQ_0, handler);
-        irq_set_enabled(DMA_IRQ_0, true);
+        // Use DMA_IRQ_1 to avoid conflict with MicroPython's DMA_IRQ_0 shared handler
