@@ -301,7 +300,47 @@ void cvideo_dma_handler(void) {
 
     // Finally, clear the interrupt request ready for the next horizontal sync interrupt
     //
-    dma_hw->ints0 = 1u << dma_channel_0;	
+    dma_hw->ints1 = 1u << dma_channel_0;	// clear IRQ_1 status (patched from IRQ_0)
+}
+
+// Stop PIO state machines, abort DMA channels, disable IRQs and zero DAC GPIO pins.
+// Must be called from core1 -- the IRQs are owned by core1's NVIC.
+//
+void deinit_cvideo(void) {
+    // Disable IRQs first so handlers can't re-arm after we abort.
+    // PIO IRQ before DMA IRQ: the PIO handler arms the pixel DMA;
+    // the DMA handler re-arms the sync DMA.  Disabling in this order
+    // ensures neither handler fires after the abort below.
+    irq_set_enabled(PIO0_IRQ_0, false);
+    irq_set_enabled(DMA_IRQ_1,  false);
+
+    // Abort any in-flight DMA transfers (blocks until current beat completes).
+    dma_channel_abort(dma_channel_1);   // pixel data
+    dma_channel_abort(dma_channel_0);   // sync
+
+    // Stop the PIO state machines and drain their FIFOs.
+    pio_sm_set_enabled(pio_0, sm_data, false);
+    pio_sm_set_enabled(pio_0, sm_sync, false);
+    pio_sm_clear_fifos(pio_0, sm_data);
+    pio_sm_clear_fifos(pio_0, sm_sync);
+
+    // Reclaim DAC GPIO pins from PIO control and drive them low (0 V on DAC).
+    for (uint g = gpio_base; g < (uint)(gpio_base + gpio_count); g++) {
+        gpio_init(g);               // resets pad to SIO, clears PIO mux
+        gpio_set_dir(g, GPIO_OUT);
+        gpio_put(g, 0);
+    }
+
+    // Release PIO programs and state machines so they can be re-claimed on
+    // reinit (e.g. after a soft reset without power-cycle).
+    pio_sm_unclaim(pio_0, sm_data);
+    pio_sm_unclaim(pio_0, sm_sync);
+    pio_remove_program(pio_0, &cvideo_data_program, offset_1);
+    pio_remove_program(pio_0, &cvideo_sync_program, offset_0);
+
+    // Release DMA channels for the same reason.
+    dma_channel_unclaim(dma_channel_1);
+    dma_channel_unclaim(dma_channel_0);
 }
 
